# PublishReal Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# ===========================================
# API Configuration (Required)
# ===========================================

# Backend API URL - point to your ASP.NET Core API
# Development: https://localhost:44317/api
# Production: https://your-api-domain.com/api
NEXT_PUBLIC_API_URL=https://localhost:44317/api

# ===========================================
# Optional: Analytics & Monitoring
# ===========================================

# Vercel Analytics (automatically provided on Vercel)
# VERCEL_WEB_ANALYTICS_ID=

# ===========================================
# Development Notes
# ===========================================

# 1. The backend API (PublishRealLiteApi) must be running for the frontend to work
# 2. Ensure CORS is configured in the API to allow requests from your frontend URL
# 3. For local development, the API typically runs on https://localhost:44317
# 4. For production, update NEXT_PUBLIC_API_URL to your deployed API endpoint
